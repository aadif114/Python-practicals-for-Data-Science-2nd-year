# a. Find the largest number in a list
numbers = [12, 45, 67, 23, 89, 34]
largest = max(numbers)
print("a. Largest number in the list:", largest)

# b. Remove duplicates from a list
duplicate_list = [1, 2, 3, 2, 4, 5, 1, 6]
unique_list = list(set(duplicate_list))
print("\nb. List after removing duplicates:", unique_list)

# c. Count how many even numbers are in a list
num_list = [10, 15, 20, 25, 30, 35, 40]
even_count = 0

for num in num_list:
    if num % 2 == 0:
        even_count += 1

print("\nc. Number of even numbers:", even_count)

# d. Input 5 numbers and store them in a list, then display the list
user_numbers = []

print("\nd. Enter 5 numbers:")
for i in range(5):
    num = int(input(f"Enter number {i + 1}: "))
    user_numbers.append(num)

print("List entered by the user:", user_numbers)

# e. Function that returns the average of all numbers in a list
def calculate_average(lst):
    return sum(lst) / len(lst)

average = calculate_average(numbers)
print("\ne. Average of the list:", average)

# f. Convert a string into a list of characters using list()
text = "Python"
char_list = list(text)
print("\nf. List of characters:", char_list)

# g. Join all elements of a list into a single string using join()
words = ["Python", "is", "easy", "to", "learn"]
joined_string = " ".join(words)
print("\ng. Joined string:", joined_string)
